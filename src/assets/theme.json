{
    "background": "#ffffff",
    "foreground": "#333333",
    
    "treeview": {
        "background": "#ffffff",
        "foreground": "#333333",
        "fieldbackground": "#ffffff",
        "header_background": "#f0f0f0",
        "header_foreground": "#333333",
        "selected_background": "#0078d7",
        "selected_foreground": "#ffffff"
    },
    
    "button": {
        "background": "#f0f0f0",
        "foreground": "#333333",
        "accent_background": "#0078d7",
        "accent_foreground": "#ffffff",
        "danger_background": "#d9534f",
        "danger_foreground": "#ffffff"
    },
    
    "entry": {
        "background": "#ffffff",
        "foreground": "#333333",
        "disabled_background": "#f0f0f0",
        "disabled_foreground": "#999999"
    },
    
    "colors": {
        "primary": "#0078d7",
        "secondary": "#6c757d",
        "success": "#28a745",
        "danger": "#d9534f",
        "warning": "#ffc107",
        "info": "#17a2b8"
    },
    
    "fonts": {
        "default": {
            "family": "Helvetica",
            "size": 12
        },
        "heading": {
            "family": "Helvetica",
            "size": 24,
            "weight": "bold"
        },
        "small": {
            "family": "Helvetica",
            "size": 10
        }
    },
    
    "spacing": {
        "small": 5,
        "medium": 10,
        "large": 20
    },
    
    "borders": {
        "radius": 4,
        "width": 1,
        "color": "#dddddd"
    }
}
